# VaultMend .gitignore

# Loop runtime artifacts (task-specific, not shared)
scripts/_archive/
scripts/_log.jsonl
scripts/journals/
scripts/*.local.json

# Task output (generated by phase1-auto.ps1)
vaultmend-tasks/

# macOS / Windows / IDE noise
.DS_Store
Thumbs.db
*.swp
*~

# Loop temporary files
*.tmp
*.bak

# Local config overrides (user-specific)
.looprc.json
